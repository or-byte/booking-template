generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  fullName         String
  email            String    @unique
  role             Role
  createdAt        DateTime  @default(now())
  createdPackages  Package[] @relation("PackageCreatedBy")
  reviewedPackages Package[] @relation("PackageReviewedBy")
  approvedPackages Package[] @relation("PackageApprovedBy")
  updatedPackaged  Package[] @relation("PackageUpdatedBy")
}

model Category {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String

  products Product[]
}

model Product {
  id          Int     @id @default(autoincrement())
  sku         String  @unique
  name        String
  description String
  price       Decimal @db.Decimal(10, 2)
  stockQty    Int     @default(0)

  categoryId   Int
  category     Category      @relation(fields: [categoryId], references: [id])
  packageItems PackageItem[]
  rooms        Room[]
}

model Package {
  id Int @id @default(autoincrement())

  createdById Int
  createdBy   User @relation(name: "PackageCreatedBy", fields: [createdById], references: [id])

  reviewedById Int?
  reviewedBy   User? @relation(name: "PackageReviewedBy", fields: [reviewedById], references: [id])

  approvedById Int?
  approvedBy   User? @relation(name: "PackageApprovedBy", fields: [approvedById], references: [id])

  updatedById Int?
  updatedBy   User? @relation(name: "PackageUpdatedBy", fields: [updatedById], references: [id])

  description   String
  overridePrice Decimal? @db.Decimal(10, 2)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  packageItems PackageItem[]
}

model PackageItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  packageId Int
  package   Package @relation(fields: [packageId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

model Room {
  id        Int     @id @default(autoincrement())
  name      String
  capacity  Int
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}
