generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          Role     @default(CUSTOMER)
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  packageEvents PackageEvent[]
  bookings      Booking[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Category {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String

  products Product[]
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  price       Decimal @db.Decimal(10, 2)
  stockQty    Int     @default(0)

  categoryId   Int
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  packageItems PackageItem[]
  rooms        Room[]
  images       Image[]
}

model Package {
  id Int @id @default(autoincrement())

  companyName     String
  contactNumber   String
  contactEmail    String
  numberOfGuests  Int
  eventDate       DateTime
  durationInDays  Int
  reservationDate DateTime?

  title         String
  overridePrice Decimal? @db.Decimal(10, 2)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  packageItems  PackageItem[]
  packageEvents PackageEvent[]
}

model PackageItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  packageId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

model PackageEvent {
  id        Int     @id @default(autoincrement())
  packageId Int
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  type PackageEventType

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([packageId, createdAt])
}

model Room {
  id        Int       @id @default(autoincrement())
  name      String
  capacity  Int
  productId Int
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  bookings  Booking[]
}

model Image {
  id        Int       @id @default(autoincrement())
  title     String
  url       String
  productId Int
  product   Product   @relation(fields: [productId], references: [id])
}

model Booking {
  id Int @id @default(autoincrement())

  leadGuestId String
  leadGuest   User   @relation(fields: [leadGuestId], references: [id])

  datetimeRange Unsupported("tstzrange")

  room   Room @relation(fields: [roomId], references: [id])
  roomId Int

  status  BookingStatus
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum PackageEventType {
  CREATED
  MODIFIED
  REVIEWED
  APPROVED
  REJECTED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKEDIN
  NOSHOW
  CANCELLED
  COMPLETED
}
